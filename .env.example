# Agent HTTP Server Configuration
# Copy this file to .env and update values as needed

# Server settings
HOST=0.0.0.0
PORT=8000
DEBUG=false

# AWS settings
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your-account-id

# AgentCore Runtime settings (set after deploying AgentCore)
AGENT_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:your-account-id:agent-runtime/ugc-website-generator
AGENTCORE_QUALIFIER=DEFAULT

# AgentCore Memory settings (create with: agentcore memory create)
AGENTCORE_MEMORY_ID=mem-xxxxxxxxxxxx

# Deployment resources - Static (S3 + CloudFront)
STATIC_S3_BUCKET=ugc-static-947472889616-us-east-1
STATIC_CLOUDFRONT_DOMAIN=d2x3r9mhi9wvmb.cloudfront.net

# Deployment resources - Dynamic (Lambda)
DYNAMIC_LAMBDA_FUNCTION=ugc-dynamic-example
DYNAMIC_FUNCTION_URL=https://r4a7c2xrpqkh7go3cmjazjppsm0uanpm.lambda-url.us-east-1.on.aws/

# Model settings for Bedrock
# Code generation uses Claude Sonnet (cross-region inference profile)
DEFAULT_MODEL=us.anthropic.claude-sonnet-4-20250514-v1:0
# Cost-optimized tasks use Nova 2 Lite
FAST_MODEL=amazon.nova-2-lite-v1:0
# Reasoning tasks use Nova 2 Lite with extended thinking
REASONING_MODEL=amazon.nova-2-lite-v1:0

# CORS settings (comma-separated origins)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Timeouts (seconds)
REQUEST_TIMEOUT=300
GENERATION_TIMEOUT=180
